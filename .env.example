# Directory that n8n downloads project subfolders into
# Each project should be in its own subfolder, e.g. WATCH_DIR/project_name/210-12345-01.pdf
WATCH_DIR=/path/to/your/downloads

# n8n webhook URL to trigger the missing-drawing email
# Since the Python agent and n8n run on the SAME Hostinger server you can use localhost:
#   N8N_WEBHOOK_URL=http://localhost:5678/webhook/drawing-alert
# Or the public URL (copy from the Webhook node in n8n → Production URL):
N8N_WEBHOOK_URL=http://localhost:5678/webhook/drawing-alert

# Optional: seconds to wait after the last file event before processing
# Increase this if large files take longer to finish downloading
SETTLE_SECONDS=5
